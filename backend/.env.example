# =============================================
# MEDICINE DETECTION APP — ENVIRONMENT CONFIG
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB ---
# Local:  mongodb://localhost:27017/medicine_detection
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/medicine_detection
MONGODB_URI=mongodb://localhost:27017/medicine_detection

# --- Anthropic Claude API ---
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=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
# --- OpenFDA API ---
# Free — no key required.
# Register for higher rate limits: https://open.fda.gov/apis/authentication/
FDA_API_BASE_URL=https://api.fda.gov/drug

# --- Frontend origin (for CORS) ---
# Change this if your Live Server runs on a different port
FRONTEND_URL=http://127.0.0.1:5500
